# ==============================================================================
# Python Environment & Caching
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ipynb_checkpoints/

# Ignore the virtual environment folder
venv/
env/
ENV/

# ==============================================================================
# IDEs and OS Specific Files
# ==============================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ==============================================================================
# Relational Databases (Local SQLite)
# ==============================================================================
# Ignores your local SQLite database file to prevent multi-megabyte binary commits
*.db
olist_ecommerce.db

# ==============================================================================
# Data & Large Files
# ==============================================================================
# Ignore the raw Kaggle CSV datasets (~100k records will bloat Git history)
data/*.csv

# Ignore final cleaned data exports to keep the repository snappy
exports/